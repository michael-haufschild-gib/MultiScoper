---
# Oscil .clang-tidy — all warnings are errors.
#
# Run: cmake --preset dev -DOSCIL_ENABLE_CLANG_TIDY=ON
# Or standalone: clang-tidy -p build/dev src/core/Source.cpp
#
# Excluded checks:
#   modernize-use-trailing-return-type — conflicts with JUCE style
#   modernize-use-nodiscard — too noisy with JUCE callback overrides
#   bugprone-easily-swappable-parameters — JUCE APIs require positional params
#   performance-unnecessary-value-param — JUCE passes juce::String by value idiomatically
#   readability-identifier-length — short names (i, x, ch) are fine in DSP code
#   modernize-avoid-c-arrays — JUCE APIs use C arrays for audio buffers
#   readability-magic-numbers — audio code legitimately uses numeric constants
#   bugprone-narrowing-conversions — JUCE mixes int/float constantly
#   performance-avoid-endl — not relevant for audio plugin (no iostream)
#   modernize-use-equals-default — JUCE constructors often need explicit empty bodies
#   readability-convert-member-functions-to-static — conflicts with JUCE override patterns
#   concurrency-mt-unsafe — flags C stdlib functions (getenv, strtok) that JUCE uses internally

Checks: >
  bugprone-*,
  concurrency-*,
  performance-*,
  modernize-*,
  readability-function-cognitive-complexity,
  readability-function-size,
  readability-implicit-bool-conversion,
  -modernize-use-trailing-return-type,
  -modernize-use-nodiscard,
  -modernize-avoid-c-arrays,
  -modernize-use-equals-default,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -performance-unnecessary-value-param,
  -performance-avoid-endl,
  -concurrency-mt-unsafe,

# ALL enabled checks are treated as errors — no warnings.
WarningsAsErrors: '*'

HeaderFilterRegex: 'include/.*\.h$'

CheckOptions:
  # Cognitive complexity: max 25 per function (McCabe-like)
  - key: readability-function-cognitive-complexity.Threshold
    value: 25
  - key: readability-function-cognitive-complexity.DescribeBasicIncrements
    value: false

  # Function size limits (backup for size_lint.py)
  - key: readability-function-size.LineThreshold
    value: 60
  - key: readability-function-size.StatementThreshold
    value: 50
  - key: readability-function-size.BranchThreshold
    value: 15
  - key: readability-function-size.ParameterThreshold
    value: 8
  - key: readability-function-size.NestingThreshold
    value: 5

  # Implicit bool conversion — catches int-to-bool and float-to-bool bugs.
  # Pointer conditions (if (ptr)) are allowed to match JUCE idioms.
  - key: readability-implicit-bool-conversion.AllowPointerConditions
    value: true
  - key: readability-implicit-bool-conversion.AllowIntegerConditions
    value: false

  # Performance tuning
  - key: performance-move-const-arg.CheckTriviallyCopyableMove
    value: false
  - key: performance-unnecessary-copy-initialization.AllowedTypes
    value: 'juce::String;juce::Identifier;juce::Colour'

  # Modernize tuning
  - key: modernize-use-auto.MinTypeNameLength
    value: 5
  - key: modernize-loop-convert.MinConfidence
    value: reasonable
  - key: modernize-pass-by-value.IncludeStyle
    value: llvm
...
