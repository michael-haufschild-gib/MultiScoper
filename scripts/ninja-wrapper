#!/usr/bin/env bash
# Ninja wrapper — set as CMAKE_MAKE_PROGRAM so every cmake --build invocation
# automatically kills stale builds before starting a new one.
#
# How it works:
#   1. Reads the PID file from the build directory
#   2. Kills the previous ninja + its child processes (clang, etc.)
#   3. Writes its own PID file
#   4. Execs the real ninja
#
# The PID file lives at <build_dir>/.ninja.pid

set -euo pipefail

REAL_NINJA="$(command -v ninja)"
if [ -z "$REAL_NINJA" ] || [ "$REAL_NINJA" = "$0" ]; then
    # Avoid infinite recursion — find ninja excluding ourselves
    REAL_NINJA="$(which -a ninja 2>/dev/null | grep -v "$(realpath "$0")" | head -1)"
fi

if [ -z "$REAL_NINJA" ]; then
    echo "[ninja-wrapper] ERROR: Cannot find real ninja binary" >&2
    exit 1
fi

# Ninja is invoked from the build directory (CMake sets cwd)
BUILD_DIR="${PWD}"
PIDFILE="${BUILD_DIR}/.ninja.pid"

# Kill previous build if still running
if [ -f "$PIDFILE" ]; then
    old_pid=$(cat "$PIDFILE" 2>/dev/null || true)
    if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
        echo "[ninja-wrapper] Killing previous build (PID $old_pid)..." >&2
        # Kill the process group to catch clang children
        kill -- -"$old_pid" 2>/dev/null || kill "$old_pid" 2>/dev/null || true
        # Brief wait, then force-kill stragglers
        sleep 1
        if kill -0 "$old_pid" 2>/dev/null; then
            kill -9 -- -"$old_pid" 2>/dev/null || kill -9 "$old_pid" 2>/dev/null || true
        fi
    fi
    rm -f "$PIDFILE"
fi

# Record our PID so the next build can kill us
echo $$ > "$PIDFILE"

# Clean up PID file on exit (normal or signal)
cleanup() {
    rm -f "$PIDFILE"
}
trap cleanup EXIT

# Cap parallel jobs at 4 to prevent system overload (clang is memory-hungry).
# This is enforced here so every build path (cmake --build, direct ninja) respects it.
# Users can still lower with -j2, but never exceed 4.
MAX_JOBS=4

# Check if the user already passed -j (with or without space); if so, cap it
HAS_J=false
CAPPED_ARGS=()
SKIP_NEXT=false
ARGS=("$@")
for (( i=0; i<${#ARGS[@]}; i++ )); do
    arg="${ARGS[$i]}"

    if [ "$SKIP_NEXT" = true ]; then
        SKIP_NEXT=false
        continue
    fi

    # -jN (no space)
    if [[ "$arg" =~ ^-j([0-9]+)$ ]]; then
        HAS_J=true
        requested="${BASH_REMATCH[1]}"
        if (( requested > MAX_JOBS )); then
            CAPPED_ARGS+=("-j${MAX_JOBS}")
        else
            CAPPED_ARGS+=("$arg")
        fi
    # -j N (with space) — next arg is the count
    elif [[ "$arg" == "-j" ]] && (( i+1 < ${#ARGS[@]} )) && [[ "${ARGS[$((i+1))]}" =~ ^[0-9]+$ ]]; then
        HAS_J=true
        requested="${ARGS[$((i+1))]}"
        SKIP_NEXT=true
        if (( requested > MAX_JOBS )); then
            CAPPED_ARGS+=("-j${MAX_JOBS}")
        else
            CAPPED_ARGS+=("-j${requested}")
        fi
    # -t (tool mode) — pass through without adding -j
    elif [[ "$arg" == "-t" ]]; then
        # Tool mode: pass all remaining args verbatim, no -j injection
        exec "$REAL_NINJA" "$@"
    else
        CAPPED_ARGS+=("$arg")
    fi
done

if [ "$HAS_J" = false ]; then
    CAPPED_ARGS+=("-j${MAX_JOBS}")
fi

exec "$REAL_NINJA" "${CAPPED_ARGS[@]}"
