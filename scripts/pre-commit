#!/usr/bin/env bash
# Oscil pre-commit hook — fast lint gate.
# Blocks commits that fail formatting, size limits, or test quality checks.
#
# Install: ./scripts/install-hooks.sh
# Skip (emergency only): git commit --no-verify

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

REPO_ROOT="$(git rev-parse --show-toplevel)"
FAILED=0

# Collect staged C/C++ files
STAGED_CPP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(cpp|h|hpp|cc|cxx|hxx)$' || true)
STAGED_TESTS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^tests/test_.*\.cpp$' || true)
STAGED_E2E=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^tests/e2e/.*\.py$' || true)

echo "━━━ Oscil Pre-Commit Checks ━━━"

# ─── 1. clang-format ───
if [ -n "$STAGED_CPP" ]; then
    if command -v clang-format &>/dev/null; then
        echo -n "  clang-format... "
        FORMAT_ERRORS=""
        for file in $STAGED_CPP; do
            if [ -f "$file" ]; then
                DIFF=$(clang-format --dry-run --Werror "$file" 2>&1 || true)
                if [ -n "$DIFF" ]; then
                    FORMAT_ERRORS="${FORMAT_ERRORS}\n    ${file}"
                fi
            fi
        done
        if [ -n "$FORMAT_ERRORS" ]; then
            echo -e "${RED}FAILED${NC}"
            echo -e "  Files with formatting issues:${FORMAT_ERRORS}"
            echo "  Run: clang-format -i <file> to fix"
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    else
        echo -e "  clang-format... ${YELLOW}SKIPPED${NC} (not installed)"
    fi
else
    echo "  clang-format... no C/C++ files staged"
fi

# ─── 2. Size lint ───
if [ -n "$STAGED_CPP" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/size_lint.py" ]; then
        echo -n "  size-lint... "
        # Run full size lint; filter violations to only staged files.
        STAGED_FILE_LIST=$(mktemp)
        echo "$STAGED_CPP" > "$STAGED_FILE_LIST"
        SIZE_OUTPUT=$(python3 "$REPO_ROOT/scripts/size_lint.py" \
            --root "$REPO_ROOT" \
            --paths include src tests test_harness \
            --max-file-lines 550 \
            --max-function-lines 75 2>&1 || true)
        STAGED_VIOLATIONS=$(echo "$SIZE_OUTPUT" | grep -F -f "$STAGED_FILE_LIST" || true)
        rm -f "$STAGED_FILE_LIST"
        if [ -n "$STAGED_VIOLATIONS" ]; then
            VIOLATION_COUNT=$(echo "$STAGED_VIOLATIONS" | wc -l | tr -d ' ')
            echo -e "${RED}FAILED${NC} ($VIOLATION_COUNT violations in staged files)"
            echo "$STAGED_VIOLATIONS" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
else
    echo "  size-lint... no C/C++ files staged"
fi

# ─── 3. Test quality lint ───
if [ -n "$STAGED_TESTS" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/test_quality_lint.py" ]; then
        echo -n "  test-quality... "
        # Check only staged test files
        TQ_EXIT=0
        TQ_OUTPUT=$(python3 "$REPO_ROOT/scripts/test_quality_lint.py" \
            --root "$REPO_ROOT" \
            --files $STAGED_TESTS 2>&1) || TQ_EXIT=$?
        if [ $TQ_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$TQ_OUTPUT" | grep -E "(ERROR|FAILED)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
else
    echo "  test-quality... no test files staged"
fi

# ─── 3b. E2E test quality lint ───
if [ -n "$STAGED_E2E" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/e2e_test_lint.py" ]; then
        echo -n "  e2e-test-lint... "
        E2E_EXIT=0
        E2E_OUTPUT=$(python3 "$REPO_ROOT/scripts/e2e_test_lint.py" \
            --root "$REPO_ROOT" \
            --files $STAGED_E2E 2>&1) || E2E_EXIT=$?
        if [ $E2E_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$E2E_OUTPUT" | grep -E "(FAILED|Violation)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
else
    echo "  e2e-test-lint... no E2E test files staged"
fi

# ─── 4. Source registry lint ───
if [ -n "$STAGED_CPP" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/source_registry_lint.py" ]; then
        echo -n "  source-registry... "
        SR_EXIT=0
        SR_OUTPUT=$(python3 "$REPO_ROOT/scripts/source_registry_lint.py" \
            --root "$REPO_ROOT" 2>&1) || SR_EXIT=$?
        if [ $SR_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$SR_OUTPUT" | grep -E "(Orphan|Stale|Duplicate|FAILED)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
fi

# ─── 5. TODO lint ───
if [ -n "$STAGED_CPP" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/todo_lint.py" ]; then
        echo -n "  todo-lint... "
        TODO_EXIT=0
        TODO_OUTPUT=$(python3 "$REPO_ROOT/scripts/todo_lint.py" \
            --root "$REPO_ROOT" \
            --paths include src 2>&1) || TODO_EXIT=$?
        if [ $TODO_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$TODO_OUTPUT" | grep -E "(ERROR|FAILED|\[)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
fi

# ─── 6. Architecture lint ───
if [ -n "$STAGED_CPP" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/architecture_lint.py" ]; then
        echo -n "  architecture... "
        ARCH_EXIT=0
        ARCH_OUTPUT=$(python3 "$REPO_ROOT/scripts/architecture_lint.py" \
            --root "$REPO_ROOT" \
            --paths include src 2>&1) || ARCH_EXIT=$?
        if [ $ARCH_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$ARCH_OUTPUT" | grep -E "(must not|FAILED)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
fi

# ─── 7. Comment lint ───
if [ -n "$STAGED_CPP" ]; then
    if command -v python3 &>/dev/null && [ -f "$REPO_ROOT/scripts/comment_lint.py" ]; then
        echo -n "  comment-lint... "
        CL_EXIT=0
        CL_OUTPUT=$(python3 "$REPO_ROOT/scripts/comment_lint.py" \
            --root "$REPO_ROOT" \
            --paths include src tests test_harness \
            --doc-paths include \
            --max-violations 0 2>&1) || CL_EXIT=$?
        if [ $CL_EXIT -ne 0 ]; then
            echo -e "${RED}FAILED${NC}"
            echo "$CL_OUTPUT" | grep -E "(ERROR|FAILED|violation)" | head -20
            FAILED=1
        else
            echo -e "${GREEN}OK${NC}"
        fi
    fi
fi

# ─── 8. clang-tidy (optional — only runs if compile_commands.json exists) ───
if [ -n "$STAGED_CPP" ]; then
    # Look for clang-tidy in common locations
    CLANG_TIDY=""
    for candidate in \
        "clang-tidy" \
        "/opt/homebrew/opt/llvm/bin/clang-tidy" \
        "/usr/local/opt/llvm/bin/clang-tidy"; do
        if command -v "$candidate" &>/dev/null; then
            CLANG_TIDY="$candidate"
            break
        fi
    done

    COMPILE_DB="$REPO_ROOT/build/dev/compile_commands.json"
    if [ -n "$CLANG_TIDY" ] && [ -f "$COMPILE_DB" ]; then
        echo -n "  clang-tidy... "
        CT_ERRORS=0
        for file in $STAGED_CPP; do
            # Only check source files (not headers — they're checked via HeaderFilterRegex)
            if [[ "$file" == src/*.cpp ]]; then
                if ! "$CLANG_TIDY" -p "$REPO_ROOT/build/dev" "$REPO_ROOT/$file" --quiet 2>/dev/null; then
                    CT_ERRORS=$((CT_ERRORS + 1))
                fi
            fi
        done
        if [ $CT_ERRORS -gt 0 ]; then
            echo -e "${YELLOW}WARN${NC} ($CT_ERRORS file(s) with findings — see CI for details)"
        else
            echo -e "${GREEN}OK${NC}"
        fi
    else
        echo -e "  clang-tidy... ${YELLOW}SKIPPED${NC} (requires clang-tidy + build/dev/compile_commands.json)"
    fi
fi

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ $FAILED -ne 0 ]; then
    echo -e "${RED}Commit blocked.${NC} Fix the issues above and try again."
    echo "Emergency bypass: git commit --no-verify"
    exit 1
fi

echo -e "${GREEN}All pre-commit checks passed.${NC}"
exit 0
